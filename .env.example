# Ativa resultados reais da Google Places API (New).
GOOGLE_PLACES_API_KEY=

# Envio de campanhas por email. Mantém false até testares a conta remetente.
OUTREACH_ENABLED=false
OUTREACH_DAILY_LIMIT=20
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Nome da empresa <email@dominio.pt>"
MAIL_REPLY_TO=email@dominio.pt
